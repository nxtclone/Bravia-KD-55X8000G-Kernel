		<0 247 0x4>,
		<0 248 0x4>,
		<0 249 0x4>,
		<0 250 0x4>,
		<0 251 0x4>,
		<0 252 0x4>,
		<0 253 0x4>,
		<0 254 0x4>;
	};
	mali: mali@f0100000 {
		compatible = "arm,mali-450", "arm,mali-utgard";
		reg = <0xf0100000 0x30000>;
		interrupts = <GIC_SPI 226 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 227 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 240 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 222 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 223 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 224 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 228 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 229 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 230 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 231 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 225 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "IRQGP", "IRQGPMMU",
				  "IRQPP0", "IRQPP1", "IRQPP2","IRQPP3","IRQPPMMU0","IRQPPMMU1", "IRQPPMMU2", "IRQPPMMU3",
				  "IRQPP";
	};

/*Add system/vendor/odm entry for early mount */
	firmware {
		android {
			compatible = "android,firmware";
			vbmeta {
				compatible = "android,vbmeta";
				parts = "vbmeta,dtbo,boot,system,vendor,tzbp,linux_rootfs,3rd,factory";
			};
			fstab {
				compatible = "android,fstab";
				vendor {
					compatible = "android,vendor";
					dev = "/dev/block/platform/soc/f006d000.MSDC0/by-name/vendor";
					type = "ext4";
					mnt_flags = "ro,noauto_da_alloc";
					fsmgr_flags = "wait,avb,slotselect";
				};
			};
		};
	};
};

/include/ "trusty.dtsi"
